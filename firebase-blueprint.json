{
  "entities": {
    "Category": {
      "title": "Category",
      "description": "A menu category (e.g., Breakfast, Main Course)",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the category"
        },
        "order": {
          "type": "number",
          "description": "Display order"
        }
      },
      "required": ["name"]
    },
    "MenuItem": {
      "title": "MenuItem",
      "description": "A food or beverage item on the menu",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "The name of the item"
        },
        "price": {
          "type": "number",
          "description": "The price of the item"
        },
        "description": {
          "type": "string",
          "description": "A brief description of the item"
        },
        "image": {
          "type": "string",
          "description": "URL of the item's image"
        },
        "categoryId": {
          "type": "string",
          "description": "ID of the category this item belongs to"
        },
        "isAvailable": {
          "type": "boolean",
          "description": "Whether the item is currently available"
        },
        "isPopular": {
          "type": "boolean",
          "description": "Whether the item is a popular dish"
        }
      },
      "required": ["name", "price", "categoryId"]
    },
    "Reservation": {
      "title": "Reservation",
      "description": "A table booking request",
      "type": "object",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the person booking"
        },
        "phone": {
          "type": "string",
          "description": "Contact phone number"
        },
        "date": {
          "type": "string",
          "description": "Date of the reservation (YYYY-MM-DD)"
        },
        "time": {
          "type": "string",
          "description": "Time of the reservation"
        },
        "guests": {
          "type": "number",
          "description": "Number of guests"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "confirmed", "cancelled"],
          "description": "Status of the reservation"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "When the reservation was made"
        }
      },
      "required": ["name", "phone", "date", "time", "guests"]
    },
    "User": {
      "title": "User",
      "description": "A user of the system (admin)",
      "type": "object",
      "properties": {
        "email": {
          "type": "string",
          "description": "User's email address"
        },
        "role": {
          "type": "string",
          "enum": ["admin"],
          "description": "User's role"
        }
      },
      "required": ["email", "role"]
    }
  },
  "firestore": {
    "/categories/{categoryId}": {
      "schema": "Category",
      "description": "Menu categories"
    },
    "/menuItems/{itemId}": {
      "schema": "MenuItem",
      "description": "Menu items"
    },
    "/reservations/{reservationId}": {
      "schema": "Reservation",
      "description": "Table reservations"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Admin users"
    }
  }
}
